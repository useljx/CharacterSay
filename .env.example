# CharacterSay Configuration
# Copy this file to .env and fill in your own values.

APP_NAME=CharacterSay
DEBUG=true
SAMPLE_RATE=16000
CHANNELS=1
BLOCK_SECONDS=0.5
INPUT_DEVICE=Loopback 扬声器 (Realtek(R) Audio)

# === Volcano Engine ASR ===
VOLC_APP_ID=your_volc_app_id_here
VOLC_ACCESS_TOKEN=your_volc_access_token_here
VOLC_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async

# === LLM (OpenAI-compatible API) ===
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=doubao-seed-character-260628

# === Character ===
ACTIVE_CHARACTER=刘培强
CHARACTER_PATH=
